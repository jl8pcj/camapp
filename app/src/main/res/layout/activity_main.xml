<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#222222">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.5">

        <androidx.camera.view.PreviewView
            android:id="@+id/viewFinder"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintDimensionRatio="4:3"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:scaleType="fillCenter" />

        <FrameLayout
            android:id="@+id/mini_board"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="8dp"
            app:layout_constraintWidth_percent="0.333"
            app:layout_constraintDimensionRatio="4:3"
            app:layout_constraintBottom_toBottomOf="@+id/viewFinder"
            app:layout_constraintEnd_toEndOf="@+id/viewFinder">

            <include
                layout="@layout/view_chalkboard_content"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#333333">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="10dp">
            <Button android:id="@+id/btn_settings" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="設定" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textColor="#FFFFFF"/>

            <Button android:id="@+id/btn_capture" android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:text="撮影" android:textSize="20sp" android:textStyle="bold" android:layout_marginHorizontal="12dp" android:backgroundTint="#FF5722"/>

            <ImageButton
                android:id="@+id/btn_gallery"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:scaleType="centerCrop"
                android:background="#444444"
                android:padding="2dp"
                android:contentDescription="最新の画像" />
        </LinearLayout>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:background="#222222"
            app:tabTextColor="#88FFFFFF"
            app:tabSelectedTextColor="#FFFFFF"
            app:tabIndicatorColor="#FF5722"
            app:tabIndicatorHeight="3dp"
            app:tabMode="fixed">
            <com.google.android.material.tabs.TabItem android:text="1"/><com.google.android.material.tabs.TabItem android:text="2"/><com.google.android.material.tabs.TabItem android:text="3"/>
            <com.google.android.material.tabs.TabItem android:text="4"/><com.google.android.material.tabs.TabItem android:text="5"/><com.google.android.material.tabs.TabItem android:text="6"/>
        </com.google.android.material.tabs.TabLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:background="#FFFFFF"
        android:paddingHorizontal="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <EditText android:id="@+id/edit_task_name_input" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:inputType="text" android:text="中央区公園及び街路樹等総合維持管理業務\n(中部地区)" android:textColor="#000000" android:textSize="14sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="文字サイズ："
                    android:textColor="#333333"
                    android:textSize="12sp" />
                <RadioGroup
                    android:id="@+id/rg_task_size"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <RadioButton android:id="@+id/rb_size_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3sp" android:textSize="12sp" android:textColor="#000000"/>
                    <RadioButton android:id="@+id/rb_size_4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4sp" android:textSize="12sp" android:textColor="#000000"/>
                    <RadioButton android:id="@+id/rb_size_5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5sp" android:textSize="12sp" android:textColor="#000000" android:checked="true"/>
                </RadioGroup>
            </LinearLayout>

            <EditText android:id="@+id/edit_work_type_input" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:inputType="text" android:textColor="#000000" android:hint="工種を入力"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="12dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <Spinner android:id="@+id/spinner_location_input" android:layout_width="match_parent" android:layout_height="48dp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <Spinner android:id="@+id/spinner_route_input" android:layout_width="match_parent" android:layout_height="48dp"/>
                </LinearLayout>
            </LinearLayout>

            <EditText android:id="@+id/edit_location2_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:inputType="text"
                android:hint="位置2の内容を入力"
                android:textColor="#000000"/>

            <Spinner android:id="@+id/spinner_remarks_input" android:layout_width="match_parent" android:layout_height="48dp"/>

            <EditText android:id="@+id/edit_jv_name_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:text="南香・高重・蔵田 特定JV "
                android:inputType="text"
                android:importantForAutofill="no"
                android:textColor="#000000"/>

            <Button
                android:id="@+id/btn_reset_current_tab"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="このタブの入力を初期化"
                android:backgroundTint="#666666"
                android:textColor="#FFFFFF" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>